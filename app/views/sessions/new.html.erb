<% content_for :title, "Přihlášení — Palkres" %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch min-h-[calc(100vh-12rem)]">
  <%# ── Form ─────────────────────────────────────────────────────── %>
  <div class="flex items-center justify-center order-2 lg:order-1">
    <div class="w-full max-w-md">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
        <h1 class="text-2xl md:text-3xl font-bold mb-2">Přihlášení</h1>
        <p class="text-sm text-slate-500 mb-6">Zadejte své údaje pro pokračování do účtu.</p>

        <%= form_with url: session_url, local: true, class: "space-y-4" do |form| %>
          <div>
            <label for="email_address" class="block text-xs uppercase tracking-wide text-slate-500 font-semibold mb-1">E-mail</label>
            <div class="relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <%= form.email_field :email_address,
                    id: "email_address",
                    required: true,
                    autofocus: true,
                    autocomplete: "username",
                    inputmode: "email",
                    placeholder: "vase@adresa.cz",
                    value: params[:email_address],
                    class: "w-full min-h-12 pl-12 pr-4 py-3 border border-slate-200 rounded-lg text-base focus:border-rose-400 focus:ring-2 focus:ring-rose-100 outline-none" %>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label for="password" class="block text-xs uppercase tracking-wide text-slate-500 font-semibold">Heslo</label>
              <%= link_to "Zapomenuté heslo?", new_password_path,
                          class: "text-xs text-rose-600 hover:underline" %>
            </div>
            <div class="relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
              <%= form.password_field :password,
                    id: "password",
                    required: true,
                    autocomplete: "current-password",
                    placeholder: "••••••••",
                    maxlength: 72,
                    class: "w-full min-h-12 pl-12 pr-4 py-3 border border-slate-200 rounded-lg text-base focus:border-rose-400 focus:ring-2 focus:ring-rose-100 outline-none" %>
            </div>
          </div>

          <%= form.submit "Přihlásit se",
                class: "w-full min-h-12 bg-rose-600 hover:bg-rose-700 active:bg-rose-800 text-white font-semibold rounded-full px-6 py-3 cursor-pointer text-base transition" %>
        <% end %>

        <div class="mt-6 pt-6 border-t border-slate-100 text-center text-sm text-slate-500">
          Nemáte ještě účet?
          <%= link_to "Vytvoříte si ho při první objednávce", root_path, class: "text-rose-600 hover:underline font-medium" %>
        </div>
      </div>

      <div class="mt-4 text-center text-xs text-slate-400">
        🔒 Přihlášení probíhá zabezpečeně přes HTTPS.
      </div>
    </div>
  </div>

  <%# ── Brand panel (lg+ only) ───────────────────────────────────── %>
  <aside class="hidden lg:flex relative bg-gradient-to-br from-rose-500 via-rose-600 to-amber-500 rounded-3xl p-10 xl:p-14 text-white items-center order-1 lg:order-2 overflow-hidden">
    <div class="relative z-10 max-w-md">
      <div class="text-sm uppercase tracking-widest opacity-75 mb-3">Palkres</div>
      <h2 class="text-3xl xl:text-4xl font-bold leading-tight">Výtvarné potřeby<br>pro radost z tvorby</h2>
      <p class="mt-4 text-base xl:text-lg text-white/90 leading-relaxed">
        Pastelky, fixy, barvy, papíry, bloky a pomůcky od kvalitních značek.<br>
        Přihlaste se a sledujte své objednávky a uložené adresy.
      </p>
      <ul class="mt-6 space-y-2 text-sm">
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
          Historie objednávek a fakturační údaje na jednom místě
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
          Rychlejší pokladna při dalším nákupu
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
          Speciální dealer ceny pro registrované velkoobchodníky
        </li>
      </ul>
    </div>
    <%# decorative blobs %>
    <div class="absolute -top-20 -right-20 w-60 h-60 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-amber-200/20 rounded-full blur-3xl"></div>
  </aside>
</div>
