<div class="flex items-end justify-between mb-5 gap-3 flex-wrap">
  <div>
    <h1 class="text-2xl md:text-3xl font-bold">Objednávky</h1>
    <p class="text-sm text-slate-500 mt-1"><%= number_with_delimiter(@counts[:total]) %> celkem · tržby <%= format_price_cents(@revenue_paid) %></p>
  </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 p-4 mb-4">
  <%= form_with url: admin_orders_path, method: :get, local: true, class: "flex flex-col md:flex-row gap-3" do |f| %>
    <div class="relative flex-1">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <%= f.search_field :q, value: params[:q], placeholder: "Číslo objednávky nebo e-mail…",
                         class: "w-full min-h-11 pl-11 pr-4 py-2 border border-slate-200 rounded-lg text-base focus:border-rose-400 focus:ring-2 focus:ring-rose-100 outline-none" %>
    </div>
    <%= f.submit "Hledat", class: "min-h-11 bg-slate-900 hover:bg-slate-800 text-white rounded-lg px-5 text-sm font-medium cursor-pointer" %>
  <% end %>

  <div class="mt-3 flex flex-wrap gap-2 text-sm overflow-x-auto">
    <%
      filters = [
        { key: nil,          label: "Vše",          count: @counts[:total] },
        { key: "placed",     label: "Nové",         count: @counts[:placed] },
        { key: "processing", label: "Zpracování",   count: @counts[:processing] },
        { key: "shipped",    label: "Odeslané",     count: @counts[:shipped] },
        { key: "delivered",  label: "Doručené",     count: @counts[:delivered] },
        { key: "cancelled",  label: "Zrušené",      count: @counts[:cancelled] }
      ]
    %>
    <% filters.each do |f| %>
      <% active = params[:status].to_s == f[:key].to_s %>
      <%= link_to admin_orders_path(request.query_parameters.merge(status: f[:key]).reject { |_, v| v.blank? }),
                  class: "whitespace-nowrap inline-flex items-center gap-1 min-h-9 px-3 rounded-full border #{active ? 'bg-rose-600 text-white border-rose-600' : 'bg-white text-slate-700 border-slate-200 hover:border-rose-300'}" do %>
        <%= f[:label] %>
        <% if f[:count] %>
          <span class="text-xs <%= active ? 'opacity-75' : 'text-slate-400' %>"><%= number_with_delimiter(f[:count]) %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Mobile cards %>
<div class="md:hidden space-y-3">
  <% @orders.each do |o| %>
    <%= link_to admin_order_path(o), class: "block bg-white border border-slate-200 rounded-xl p-4 hover:border-rose-300 hover:shadow-sm" do %>
      <div class="flex items-baseline justify-between gap-2">
        <div class="font-mono font-semibold text-rose-600"><%= o.number %></div>
        <div class="text-xs text-slate-400"><%= o.created_at.strftime("%-d. %-m. %H:%M") %></div>
      </div>
      <div class="text-sm text-slate-600 mt-0.5 truncate"><%= o.email %></div>
      <div class="flex items-center justify-between mt-2">
        <div class="flex items-center gap-1.5 flex-wrap">
          <span class="text-xs px-2 py-0.5 rounded-full <%= status_badge_class(o.status) %>"><%= o.status %></span>
          <span class="text-xs px-2 py-0.5 rounded-full <%= payment_badge_class(o.payment_state) %>"><%= o.payment_state %></span>
        </div>
        <div class="font-bold whitespace-nowrap"><%= format_price_cents(o.total_cents) %></div>
      </div>
    <% end %>
  <% end %>
</div>

<%# Desktop table %>
<div class="hidden md:block bg-white rounded-xl border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
      <tr>
        <th class="p-3 text-left">Číslo</th>
        <th class="p-3 text-left">Datum</th>
        <th class="p-3 text-left">Zákazník</th>
        <th class="p-3 text-center">Položek</th>
        <th class="p-3 text-center">Stav</th>
        <th class="p-3 text-center">Platba</th>
        <th class="p-3 text-right">Celkem</th>
        <th class="p-3 w-10"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @orders.each do |o| %>
        <tr class="hover:bg-slate-50">
          <td class="p-3"><%= link_to o.number, admin_order_path(o), class: "font-mono text-rose-600 hover:underline" %></td>
          <td class="p-3 text-slate-600"><%= o.created_at.strftime("%-d. %-m. %Y %H:%M") %></td>
          <td class="p-3 text-slate-700 truncate max-w-[200px]"><%= o.email %></td>
          <td class="p-3 text-center text-slate-500"><%= o.order_items.size %></td>
          <td class="p-3 text-center"><span class="text-xs px-2 py-0.5 rounded-full <%= status_badge_class(o.status) %>"><%= o.status %></span></td>
          <td class="p-3 text-center"><span class="text-xs px-2 py-0.5 rounded-full <%= payment_badge_class(o.payment_state) %>"><%= o.payment_state %></span></td>
          <td class="p-3 text-right font-semibold whitespace-nowrap"><%= format_price_cents(o.total_cents) %></td>
          <td class="p-3 text-right"><%= link_to "→", admin_order_path(o), class: "inline-flex items-center justify-center w-8 h-8 rounded-full hover:bg-rose-100 text-rose-600 font-bold" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @orders.empty? %>
  <div class="bg-white border border-slate-200 rounded-xl p-12 text-center text-slate-500">
    <div class="text-4xl mb-2">🧾</div>
    Žádné objednávky pro tyto filtry.
  </div>
<% end %>

<%= pagy_nav_pretty(@pagy) %>
