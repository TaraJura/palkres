<!DOCTYPE html>
<html lang="cs">
  <head>
    <title><%= content_for(:title) || "Palkres — výtvarné potřeby" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#e11d48">
    <meta name="description" content="<%= content_for(:description) || "Výtvarné potřeby, papírnictví, školní sortiment. Kvalitní produkty za férové ceny." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col antialiased">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-3 md:px-4 py-2.5 md:py-3 flex items-center gap-2 md:gap-4">
        <%= link_to root_path, class: "flex items-center font-bold text-lg md:text-xl tracking-tight shrink-0" do %>
          <span class="text-rose-600">Pal</span><span>kres</span>
        <% end %>

        <%= form_with url: search_path, method: :get, class: "flex-1 min-w-0", local: true do |f| %>
          <div class="relative">
            <%= f.search_field :q, value: params[:q], placeholder: "Hledat…",
                               autocomplete: "off", inputmode: "search",
                               class: "w-full min-h-11 rounded-full border border-slate-200 bg-slate-100 focus:bg-white focus:border-rose-400 focus:ring-2 focus:ring-rose-100 pl-4 pr-12 outline-none text-base" %>
            <button type="submit" aria-label="Hledat" class="absolute right-1.5 top-1/2 -translate-y-1/2 w-9 h-9 inline-flex items-center justify-center bg-rose-600 hover:bg-rose-700 active:bg-rose-800 text-white rounded-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            </button>
          </div>
        <% end %>

        <nav class="flex items-center gap-1.5 md:gap-3 text-sm shrink-0">
          <% if authenticated? %>
            <%= link_to account_orders_path, class: "hidden md:inline-flex items-center min-h-11 px-3 hover:text-rose-600", "aria-label": "Můj účet" do %>Můj účet<% end %>
            <%= button_to session_path, method: :delete, class: "hidden md:inline-flex items-center min-h-11 px-3 hover:text-rose-600", form_class: "inline" do %>Odhlásit<% end %>
          <% else %>
            <%= link_to new_session_path, class: "hidden md:inline-flex items-center min-h-11 px-3 hover:text-rose-600" do %>Přihlášení<% end %>
            <%= link_to new_session_path, class: "md:hidden inline-flex items-center justify-center w-11 h-11 text-slate-700 hover:text-rose-600", "aria-label": "Přihlášení" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <% end %>
          <% end %>
          <%= link_to kosik_path, class: "relative inline-flex items-center gap-2 bg-slate-900 text-white rounded-full pl-3 pr-2 md:pr-4 min-h-11 hover:bg-rose-600 active:bg-rose-700", "aria-label": "Košík (#{current_cart.item_count})" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h2l2 12h12l2-8H6"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>
            <span class="hidden md:inline">Košík</span>
            <span class="inline-flex items-center justify-center min-w-[1.5rem] h-6 px-1.5 bg-white text-slate-900 text-xs rounded-full font-semibold"><%= current_cart.item_count %></span>
          <% end %>
        </nav>
      </div>
    </header>

    <% if flash[:notice] %><div class="bg-emerald-50 border-b border-emerald-200 text-emerald-900 text-sm py-2 px-4 text-center"><%= flash[:notice] %></div><% end %>
    <% if flash[:alert]  %><div class="bg-rose-50    border-b border-rose-200    text-rose-900    text-sm py-2 px-4 text-center"><%= flash[:alert]  %></div><% end %>

    <main class="flex-1 max-w-7xl w-full mx-auto px-3 md:px-4 py-4 md:py-6">
      <%= yield %>
    </main>

    <footer class="bg-slate-900 text-slate-300 text-sm mt-10 md:mt-12">
      <div class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <div class="text-white font-semibold mb-2">Palkres s.r.o.</div>
          <p>Výtvarné potřeby, papírnictví a školní sortiment. Sortiment od ARTIKON s.r.o.</p>
        </div>
        <div>
          <div class="text-white font-semibold mb-2">Kontakt</div>
          <p>E-mail: <a href="mailto:info@palkres.cz" class="hover:text-white underline">info@palkres.cz</a></p>
        </div>
        <div>
          <div class="text-white font-semibold mb-2">Informace</div>
          <ul class="space-y-1"><li>Obchodní podmínky</li><li>Doprava a platba</li><li>Reklamace</li></ul>
        </div>
      </div>
      <div class="text-center py-3 text-xs border-t border-slate-800">© <%= Time.current.year %> Palkres s.r.o.</div>
    </footer>
  </body>
</html>
