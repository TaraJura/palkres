<% content_for :title, "Můj profil" %>
<h1 class="text-3xl font-bold mb-6">Můj profil</h1>
<%= form_with model: Current.user, url: account_profile_path, method: :patch, scope: :user, class: "bg-white border border-slate-200 rounded-2xl p-6 max-w-xl space-y-3" do |f| %>
  <%= f.text_field :first_name, placeholder: "Jméno", class: "w-full border border-slate-200 rounded-lg px-4 py-2" %>
  <%= f.text_field :last_name,  placeholder: "Příjmení", class: "w-full border border-slate-200 rounded-lg px-4 py-2" %>
  <%= f.telephone_field :phone, placeholder: "Telefon", class: "w-full border border-slate-200 rounded-lg px-4 py-2" %>
  <div><%= f.submit "Uložit", class: "bg-rose-600 hover:bg-rose-700 text-white rounded-full px-6 py-2" %></div>
<% end %>
