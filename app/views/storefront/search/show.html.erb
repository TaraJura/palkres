<% content_for :title, @query.present? ? "Hledat: #{@query}" : "Vyhledávání" %>

<%
  # Preserve current filters when building filter-toggle links
  base_params = request.query_parameters.reject { |k, _| k.to_s == "page" }

  price_min_czk = @price_range[0].to_i / 100
  price_max_czk = @price_range[1].to_i / 100
  has_filters = params[:manufacturer_id].present? || params[:in_stock] == "1" ||
                params[:price_min].present? || params[:price_max].present?
%>

<div class="bg-gradient-to-br from-rose-50 via-white to-amber-50 rounded-2xl p-6 md:p-8 mb-6">
  <h1 class="text-3xl font-bold">Vyhledávání</h1>
  <%= form_with url: search_path, method: :get, local: true, class: "mt-4 flex gap-2" do |f| %>
    <div class="flex-1 relative">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <%= f.text_field :q, value: @query, placeholder: "Hledat produkt, výrobce, SKU, EAN…", autofocus: @query.blank?,
                       class: "w-full pl-12 pr-4 py-3 bg-white border border-slate-200 rounded-full focus:outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" %>
    </div>
    <%= f.submit "Hledat", class: "bg-rose-600 hover:bg-rose-700 text-white font-medium rounded-full px-6 py-3 cursor-pointer" %>
  <% end %>
  <% if @query.present? %>
    <p class="mt-3 text-sm text-slate-600">
      Nalezeno <strong><%= @total_before_facets %></strong> produktů pro <strong>„<%= @query %>"</strong>
    </p>
  <% end %>
</div>

<% if @total_before_facets.zero? %>
  <div class="bg-white border border-slate-200 rounded-2xl p-12 text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h2 class="text-xl font-semibold mb-2">Nic jsme nenašli</h2>
    <p class="text-slate-500 mb-6 max-w-md mx-auto">
      <% if @query.present? %>
        Pro výraz <strong>„<%= @query %>"</strong> nemáme žádný produkt. Zkontrolujte překlepy, zkuste obecnější výraz nebo prohledejte celý sortiment.
      <% else %>
        Zadejte, co hledáte — produkt, značku, kódy SKU nebo EAN.
      <% end %>
    </p>
    <% if @query.present? %>
      <%= link_to "Zobrazit celý katalog", root_path, class: "inline-block bg-rose-600 hover:bg-rose-700 text-white rounded-full px-5 py-2.5 font-medium" %>
    <% end %>
    <% if @root_categories.any? %>
      <div class="mt-8">
        <div class="text-xs uppercase text-slate-400 mb-3">Nebo vyberte kategorii</div>
        <div class="flex flex-wrap gap-2 justify-center">
          <% @root_categories.first(8).each do |c| %>
            <%= link_to c.name, category_path_for(c), class: "bg-slate-100 hover:bg-rose-100 text-sm rounded-full px-3 py-1.5" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6">
    <aside class="space-y-5">
      <div class="bg-white border border-slate-200 rounded-2xl p-5 sticky top-20">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold">Filtry</h2>
          <% if has_filters %>
            <%= link_to "× vyčistit", search_path(q: @query), class: "text-xs text-rose-600 hover:underline" %>
          <% end %>
        </div>

        <%= form_with url: search_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <%= hidden_field_tag :q, @query %>
          <%= hidden_field_tag :sort, @sort %>

          <div>
            <div class="text-xs uppercase text-slate-500 mb-2">Cena (Kč)</div>
            <div class="flex items-center gap-2">
              <%= number_field_tag :price_min, params[:price_min], placeholder: "od", min: 0,
                                   class: "w-full border border-slate-200 rounded-lg px-3 py-1.5 text-sm" %>
              <span class="text-slate-400">–</span>
              <%= number_field_tag :price_max, params[:price_max], placeholder: "do", min: 0,
                                   class: "w-full border border-slate-200 rounded-lg px-3 py-1.5 text-sm" %>
            </div>
            <div class="text-xs text-slate-400 mt-1">Rozsah: <%= price_min_czk %> – <%= price_max_czk %> Kč</div>
          </div>

          <label class="flex items-center gap-2 cursor-pointer">
            <%= check_box_tag :in_stock, "1", params[:in_stock] == "1",
                              class: "w-4 h-4 text-rose-600 border-slate-300 rounded focus:ring-rose-400" %>
            <span class="text-sm">Pouze skladem</span>
          </label>

          <%= f.submit "Filtrovat", class: "w-full bg-slate-900 hover:bg-rose-600 text-white rounded-full py-2 text-sm cursor-pointer" %>
        <% end %>

        <% if @manufacturer_facets.any? %>
          <div class="mt-5 pt-5 border-t border-slate-100">
            <div class="text-xs uppercase text-slate-500 mb-2">Výrobce</div>
            <ul class="space-y-1 max-h-72 overflow-y-auto text-sm">
              <% @manufacturer_facets.each do |mid, mname, count| %>
                <li>
                  <% if params[:manufacturer_id].to_i == mid %>
                    <%= link_to url_for(base_params.except(:manufacturer_id).merge(only_path: true)),
                                class: "flex items-center justify-between rounded px-2 py-1 bg-rose-100 text-rose-800 font-medium" do %>
                      <span>✓ <%= mname %></span><span class="text-xs"><%= count %></span>
                    <% end %>
                  <% else %>
                    <%= link_to url_for(base_params.merge(manufacturer_id: mid, only_path: true)),
                                class: "flex items-center justify-between rounded px-2 py-1 hover:bg-slate-50" do %>
                      <span><%= mname %></span><span class="text-xs text-slate-400"><%= count %></span>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </aside>

    <div>
      <div class="bg-white border border-slate-200 rounded-2xl px-4 py-3 mb-4 flex flex-wrap items-center justify-between gap-3">
        <div class="text-sm text-slate-600">
          <%== pagy_info(@pagy, item_name: "produktů") %>
          <% if has_filters %>
            <span class="ml-2 flex flex-wrap gap-1 inline-flex">
              <% if @selected_manufacturer %>
                <%= link_to url_for(base_params.except(:manufacturer_id).merge(only_path: true)),
                            class: "inline-flex items-center gap-1 bg-rose-50 text-rose-700 rounded-full px-2 py-0.5 text-xs hover:bg-rose-100" do %>
                  <%= @selected_manufacturer.name %> ×
                <% end %>
              <% end %>
              <% if params[:in_stock] == "1" %>
                <%= link_to url_for(base_params.except(:in_stock).merge(only_path: true)),
                            class: "inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 rounded-full px-2 py-0.5 text-xs hover:bg-emerald-100" do %>
                  skladem ×
                <% end %>
              <% end %>
              <% if params[:price_min].present? || params[:price_max].present? %>
                <%= link_to url_for(base_params.except(:price_min, :price_max).merge(only_path: true)),
                            class: "inline-flex items-center gap-1 bg-amber-50 text-amber-800 rounded-full px-2 py-0.5 text-xs hover:bg-amber-100" do %>
                  <%= "#{params[:price_min].presence || 0}–#{params[:price_max].presence || '∞'} Kč" %> ×
                <% end %>
              <% end %>
            </span>
          <% end %>
        </div>
        <%= form_with url: search_path, method: :get, local: true, class: "flex items-center gap-2 text-sm" do |f| %>
          <% base_params.each do |k, v| %>
            <%= hidden_field_tag k, v unless k.to_s == "sort" %>
          <% end %>
          <label class="text-slate-500">Seřadit</label>
          <%= select_tag :sort,
                options_for_select(
                  [
                    ["Relevance",        "relevance"],
                    ["Název: A–Z",       "name_asc"],
                    ["Název: Z–A",       "name_desc"],
                    ["Cena: nejnižší",   "price_asc"],
                    ["Cena: nejvyšší",   "price_desc"],
                    ["Nejnovější",       "newest"]
                  ], @sort
                ),
                onchange: "this.form.submit()",
                class: "border border-slate-200 rounded-lg px-3 py-1.5" %>
        <% end %>
      </div>

      <% if @products.any? %>
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
          <%= render partial: "storefront/products/card", collection: @products, as: :product %>
        </div>
        <%= pagy_nav_pretty(@pagy) %>
      <% else %>
        <div class="bg-white border border-slate-200 rounded-2xl p-10 text-center text-slate-500">
          Pro zadané filtry není žádný produkt. Zkuste je uvolnit.
        </div>
      <% end %>
    </div>
  </div>
<% end %>
