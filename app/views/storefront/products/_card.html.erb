<article class="bg-white border border-slate-200 rounded-2xl overflow-hidden flex flex-col hover:shadow-md transition">
  <%= link_to product_path(slug: product.slug), class: "block" do %>
    <div class="aspect-square bg-slate-50 flex items-center justify-center p-4">
      <% if product.primary_image_url %>
        <img src="<%= product.primary_image_url %>" alt="<%= product.name %>" class="max-h-full max-w-full object-contain" loading="lazy">
      <% else %>
        <div class="text-slate-300 text-5xl">⋯</div>
      <% end %>
    </div>
  <% end %>
  <div class="p-4 flex-1 flex flex-col gap-2">
    <% if product.manufacturer %>
      <div class="text-xs uppercase text-slate-400 font-semibold"><%= product.manufacturer.name %></div>
    <% end %>
    <h3 class="text-sm font-medium leading-snug line-clamp-2">
      <%= link_to product.name, product_path(slug: product.slug), class: "hover:text-rose-600" %>
    </h3>
    <div class="mt-auto flex items-end justify-between pt-2">
      <div>
        <div class="text-lg font-bold"><%= format_price_cents(product.price_retail_cents) %></div>
        <div class="text-xs text-slate-400">bez DPH <%= format_price_cents(product.price_wo_tax_cents) %></div>
      </div>
      <%= button_to "Do košíku", add_kosik_path(product_id: product.id), method: :post,
                    class: "bg-rose-600 hover:bg-rose-700 text-white rounded-full px-3 py-1.5 text-sm",
                    form_class: "inline" %>
    </div>
  </div>
</article>
