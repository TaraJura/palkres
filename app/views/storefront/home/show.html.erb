<% content_for :title, "Palkres — výtvarné potřeby pro radost z tvorby" %>

<section class="bg-gradient-to-br from-rose-100 via-white to-amber-50 rounded-3xl p-10 md:p-16 flex flex-col md:flex-row items-center gap-10 shadow-sm">
  <div class="flex-1">
    <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tight">Výtvarné potřeby<br><span class="text-rose-600">pro radost z tvorby</span></h1>
    <p class="mt-4 text-lg text-slate-600 max-w-xl">Pastelky, fixy, barvy, papíry, bloky a pomůcky od kvalitních českých i zahraničních značek. Přehledný e-shop, rychlé dodání, férové ceny.</p>
    <div class="mt-6 flex gap-3">
      <%= link_to "Prohlédnout katalog", (@featured_categories.first ? category_path_for(@featured_categories.first) : "#"), class: "bg-rose-600 hover:bg-rose-700 text-white rounded-full px-6 py-3 font-medium" %>
      <%= link_to "Hledat",              search_path, class: "bg-white hover:bg-slate-100 border border-slate-200 rounded-full px-6 py-3" %>
    </div>
  </div>
  <div class="flex-1 grid grid-cols-2 gap-3">
    <% @recent_products.first(4).each do |p| %>
      <% if p.primary_image_url %>
        <div class="bg-white rounded-2xl shadow-sm p-2"><img src="<%= p.primary_image_url %>" alt="<%= p.name %>" class="w-full h-40 object-contain" loading="lazy"></div>
      <% end %>
    <% end %>
  </div>
</section>

<section class="mt-10">
  <h2 class="text-2xl font-semibold mb-4">Hlavní kategorie</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
    <% @featured_categories.each do |c| %>
      <%= link_to category_path_for(c), class: "block bg-white hover:bg-rose-50 border border-slate-200 rounded-xl p-4 text-sm font-medium text-center hover:border-rose-300" do %>
        <%= c.name %>
        <div class="text-xs text-slate-500 mt-1"><%= c.products_count %> produktů</div>
      <% end %>
    <% end %>
  </div>
</section>

<section class="mt-10">
  <h2 class="text-2xl font-semibold mb-4">Nejnovější produkty</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    <%= render partial: "storefront/products/card", collection: @recent_products, as: :product %>
  </div>
</section>

<section class="mt-10">
  <h2 class="text-2xl font-semibold mb-4">Značky</h2>
  <div class="flex flex-wrap gap-2">
    <% @popular_manufacturers.each do |m| %>
      <span class="bg-white border border-slate-200 rounded-full px-3 py-1 text-sm"><%= m.name %></span>
    <% end %>
  </div>
</section>
